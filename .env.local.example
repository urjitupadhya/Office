# GitHub Token Pool — up to 5 tokens for parallel API fetching (20% workload each)
# Each token handles a ~20% slice of pages, all fetched concurrently.
# Add as many as you have; at least 1 is required for large repos.
GITHUB_TOKEN_1=github_pat_your_token_1
GITHUB_TOKEN_2=github_pat_your_token_2
GITHUB_TOKEN_3=github_pat_your_token_3
GITHUB_TOKEN_4=github_pat_your_token_4
GITHUB_TOKEN_5=github_pat_your_token_5

# Legacy single-token fallback (used if none of the above are set)
# GITHUB_TOKEN=github_pat_your_personal_access_token
